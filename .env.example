# Postgres connection string
DATABASE_URL=

# Must match TIC-v2's DIGITAL_PRODUCTS_PLATFORM_API_KEY
PLATFORM_INGEST_API_KEY=

# Signs session cookies — use a long random string
SESSION_SECRET=

# Public base URL of this app (used to build magic-link URLs)
APP_BASE_URL=http://localhost:3001

# Resend transactional email (leave blank in dev — magic links get logged instead)
RESEND_API_KEY=
EMAIL_FROM=

# Cloudflare R2 (S3-compatible) — where product files live
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Used only by prisma/seed.ts to wire the eBook's file key on first seed
EBOOK_R2_KEY=
